{
  "name": "tidy",
  "version": "0.1.0",
  "description": "이메일/슬랙 메시지 자동 분류·요약·태스크화 데스크탑 앱",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "rebuild:native": "node scripts/rebuild-native.js",
    "electron:dev": "node scripts/patch-electron-name.js && node scripts/rebuild-native.js && concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "dist": "node scripts/rebuild-native.js && npm run build && electron-builder"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@mediapipe/tasks-vision": "^0.10.34",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@slack/web-api": "^7.3.0",
    "better-sqlite3": "^12.9.0",
    "bplist-parser": "^0.3.2",
    "electron-store": "^8.2.0",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "html-to-docx": "^1.8.0",
    "hwp.js": "^0.0.3",
    "imapflow": "^1.0.162",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.25.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.7",
    "vite": "^6.4.2",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.tidy.app",
    "productName": "Tidy",
    "extraResources": [
      {
        "from": "resources/hwpx",
        "to": "hwpx",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
